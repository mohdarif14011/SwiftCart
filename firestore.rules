
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SwiftCart Security Rules - Prototype Version
     * Simplified for rapid development and to resolve permission blocks.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // In prototype mode, we check for the role doc, but also allow fallback
      // for the developer's current authenticated session if needed.
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        request.auth.token.email.matches('.*@swiftcart.com$')
      );
    }

    function isStaff() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        exists(/databases/$(database)/documents/roles_delivery_agent/$(request.auth.uid))
      );
    }

    // --- Collection Rules ---

    match /customers/{userId} {
      // Allow any signed-in user to see customer list/details in prototype
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /deliveryAgents/{agentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn(); // Allow onboarding
      allow update: if isOwner(agentId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isSignedIn(); // Allow easier catalog management in prototype
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      // Allow staff to see all orders, customers see their own
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow update: if isSignedIn(); // Allow agents to update status
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Allow first-time setup in prototype
    }

    match /roles_delivery_agent/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }
  }
}
