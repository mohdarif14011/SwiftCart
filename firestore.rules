
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SwiftCart Security Rules - v1.0.3
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isDeliveryAgent() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_delivery_agent/$(request.auth.uid));
    }

    // --- Collection Rules ---

    match /customers/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /deliveryAgents/{agentId} {
      allow get, list: if isSignedIn();
      allow create: if isAdmin() || isOwner(agentId);
      allow update: if isOwner(agentId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin() || isDeliveryAgent());
      // Admins and Agents can list all orders. 
      // Customers can only list orders where they are the owner.
      allow list: if isAdmin() || isDeliveryAgent() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow update: if isAdmin() || isDeliveryAgent();
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    match /roles_delivery_agent/{userId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }
  }
}
