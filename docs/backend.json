
{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a registered customer of the SwiftCart application. Stores profile and delivery information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the User entity."
        },
        "email": {
          "type": "string",
          "description": "The user's email address.",
          "format": "email"
        },
        "firstName": {
          "type": "string",
          "description": "The first name of the user."
        },
        "lastName": {
          "type": "string",
          "description": "The last name of the user."
        },
        "phone": {
          "type": "string",
          "description": "The user's contact phone number."
        },
        "address": {
          "type": "string",
          "description": "The street address for delivery."
        },
        "nearby": {
          "type": "string",
          "description": "Nearby landmarks for easier delivery."
        },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      },
      "required": [
        "id",
        "email",
        "firstName",
        "lastName"
      ]
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "description": "Defines a category for organizing products.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Category."
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name"
      ]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product in the catalog.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "price": {
          "type": "number"
        },
        "imageUrl": {
          "type": "string"
        },
        "inventory": {
          "type": "number"
        },
        "category": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "name",
        "price",
        "category"
      ]
    },
    "DeliveryAgent": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "DeliveryAgent",
      "type": "object",
      "description": "Represents a delivery agent.",
      "properties": {
        "id": {
          "type": "string"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": ["Available", "On Delivery", "Offline"]
        },
        "vehicleType": {
          "type": "string"
        },
        "joinedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["id", "firstName", "lastName", "email", "status"]
    }
  },
  "auth": {
    "providers": [
      "google.com",
      "password"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/customers/{userId}",
        "definition": {
          "entityName": "User",
          "schema": {
            "$ref": "#/backend/entities/User"
          },
          "description": "Customer profiles.",
          "params": [
            {
              "name": "userId",
              "description": "The unique identifier of the customer."
            }
          ]
        }
      },
      {
        "path": "/deliveryAgents/{agentId}",
        "definition": {
          "entityName": "DeliveryAgent",
          "schema": {
            "$ref": "#/backend/entities/DeliveryAgent"
          },
          "description": "Delivery agent profiles.",
          "params": [
            {
              "name": "agentId",
              "description": "The unique identifier of the agent."
            }
          ]
        }
      },
      {
        "path": "/products/{productId}",
        "definition": {
          "entityName": "Product",
          "schema": {
            "$ref": "#/backend/entities/Product"
          },
          "description": "Store products."
        }
      },
      {
        "path": "/categories/{categoryId}",
        "definition": {
          "entityName": "Category",
          "schema": {
            "$ref": "#/backend/entities/Category"
          },
          "description": "Product categories."
        }
      }
    ]
  }
}
